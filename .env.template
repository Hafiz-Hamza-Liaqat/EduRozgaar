# =============================================================================
# Strideto — Environment template (copy sections to the right files)
# NEVER commit real secrets. Copy this file to .env at repo root for Docker deploy.
# =============================================================================

# -----------------------------------------------------------------------------
# DOCKER / ROOT .env  (used by docker compose — copy this whole block to .env)
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-openssl-rand-hex-32
SITE_URL=https://strideto.com
FRONTEND_URL=https://strideto.com
VITE_APP_URL=https://strideto.com
VITE_API_URL=/api
FRONTEND_PORT=80

# Optional: use MongoDB Atlas instead of container MongoDB
# MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/edurozgaar?retryWrites=true&w=majority

# Optional: disable government job scraper cron (1 = disabled)
# DISABLE_SCRAPER_CRON=0

# SMTP (password reset emails) — Brevo, Resend, Gmail, etc.
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=your-smtp-login
MAIL_PASS=your-smtp-password
MAIL_FROM=Strideto <noreply@strideto.com>

# Stripe (employer job payments)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary (resume/application uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Media Library storage (C.7.0.1) — local | supabase | s3 (default: local)
# MEDIA_STORAGE_PROVIDER=local
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Optional: disable queue cron on API when worker container runs it
# DISABLE_QUEUE_CRON=1
# DISABLE_REMINDER_CRON=0
# WORKER_POLL_INTERVAL_MS=15000

# Logging & monitoring
# LOG_LEVEL=info
# SENTRY_DSN=

# MongoDB pool (production)
# MONGO_MAX_POOL_SIZE=20
# MONGO_MIN_POOL_SIZE=2

# Shutdown
# SHUTDOWN_TIMEOUT_MS=30000

# Client AdSense (build-time)
# VITE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxx
# ADMIN_EMAIL=admin@strideto.com
# ADMIN_PASSWORD=YourSecureAdminPassword123!

# -----------------------------------------------------------------------------
# SERVER — copy to server/.env for local npm run dev / PM2
# -----------------------------------------------------------------------------
# PORT=5000
# NODE_ENV=development
# MONGO_URI=mongodb://localhost:27017/edurozgaar
# JWT_SECRET=replace-with-openssl-rand-hex-32
# JWT_EXPIRES_IN=1h
# REFRESH_EXPIRES_IN=7d
# SITE_URL=http://localhost:5173
# FRONTEND_URL=http://localhost:5173
# REDIS_URL=redis://localhost:6379
# DISABLE_SCRAPER_CRON=0
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=

# -----------------------------------------------------------------------------
# CLIENT — copy to client/.env for local Vite dev
# -----------------------------------------------------------------------------
# VITE_API_URL=http://localhost:5000/api
# VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# CLIENT production build — copy to client/.env.production
# -----------------------------------------------------------------------------
# VITE_API_URL=/api
# VITE_APP_URL=https://strideto.com

# -----------------------------------------------------------------------------
# CAREER DOMAIN — TalentProfile rollout (C.8.0.2A)
# -----------------------------------------------------------------------------
# TALENT_PROFILE_ENABLED=1
# TALENT_PROFILE_DUAL_WRITE=0
# TALENT_PROFILE_READ_CANONICAL=0
# VITE_TALENT_PROFILE_ENABLED=1
# VITE_TALENT_PROFILE_READ_CANONICAL=0
# OPPORTUNITY_APPLICATION_ENABLED=1
# VITE_OPPORTUNITY_APPLICATION_ENABLED=1
# TIMELINE_ENABLED=1
# VITE_TIMELINE_ENABLED=1
# DOCUMENTS_PLATFORM_ENABLED=1
# VITE_DOCUMENTS_PLATFORM_ENABLED=1
# CAREER_DASHBOARD_ENABLED=1
# VITE_CAREER_DASHBOARD_ENABLED=1
# CAREER_DASHBOARD_V2_ENABLED=1
# VITE_CAREER_DASHBOARD_V2_ENABLED=1
# DASHBOARD_PERSONALIZATION_ENABLED=0
# VITE_DASHBOARD_PERSONALIZATION_ENABLED=0
# SCORING_ENABLED=1
# VITE_SCORING_ENABLED=1
# ASSESSMENTS_ENABLED=1
# VITE_ASSESSMENTS_ENABLED=1
# ASSESSMENT_RESULTS_ENABLED=1
# VERIFIED_CREDENTIALS_ENABLED=1
# EMPLOYER_INTELLIGENCE_ENABLED=1
# VITE_EMPLOYER_INTELLIGENCE_ENABLED=1
# APPLICATION_DUAL_WRITE — unset = ON when Opportunity Applications enabled (L.2.6 Apply→Tracker).
