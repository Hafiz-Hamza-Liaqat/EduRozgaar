# Production environment template (C.7.0.9 / L.2)
# Copy to repo root as .env before: docker compose up -d
# SSL/DNS: terminate TLS with Caddy (deploy/Caddyfile) pointing at FRONTEND_PORT.

APP_ENV=production
JWT_SECRET=replace-with-openssl-rand-hex-32
SITE_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
VITE_APP_URL=https://yourdomain.com
VITE_API_URL=/api
FRONTEND_PORT=80

# MongoDB (container default or Atlas)
# MONGO_URI=mongodb://mongodb:27017/edurozgaar

# Redis (compose sets redis://redis:6379; required when REQUIRE_REDIS=1)
REQUIRE_REDIS=1
# REDIS_URL=redis://redis:6379

# Worker: API disables queue/reminder crons; worker container processes them
DISABLE_QUEUE_CRON=1
DISABLE_REMINDER_CRON=1
# On worker, DISABLE_REMINDER_CRON defaults to 0 via compose
# DISABLE_SCRAPER_CRON=0
WORKER_POLL_INTERVAL_MS=15000

LOG_LEVEL=info
# SENTRY_DSN=

# Media: local (volume) | s3 | supabase — prefer s3/supabase for public launch durability
MEDIA_STORAGE_PROVIDER=local
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_CDN_URL=https://cdn.yourdomain.com
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
# SUPABASE_CDN_URL=

# SMTP
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=EduRozgaar <noreply@yourdomain.com>

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Cloudinary (legacy resume uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

CMS_SEED_ON_START=0

# Career flags — production matrix (dual-write OFF)
TALENT_PROFILE_ENABLED=1
TALENT_PROFILE_DUAL_WRITE=0
OPPORTUNITY_APPLICATION_ENABLED=1
APPLICATION_DUAL_WRITE=0
TIMELINE_ENABLED=1
DOCUMENTS_PLATFORM_ENABLED=1
CAREER_DASHBOARD_ENABLED=1
CAREER_DASHBOARD_V2_ENABLED=1
DASHBOARD_PERSONALIZATION_ENABLED=0
SCORING_ENABLED=1
ASSESSMENTS_ENABLED=1
EMPLOYER_INTELLIGENCE_ENABLED=1
CAREER_MIGRATION_JOBS_ENABLED=0

# Paid AI APIs — OFF (do not set OPENAI_API_KEY / ANTHROPIC_API_KEY)
# See docs/AI_BUDGET_POLICY.md — monthly AI cost ≈ $0
