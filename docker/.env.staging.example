# Staging environment template (L.2)
# Copy to repo root as .env.staging (never commit secrets).
# Generate JWT: openssl rand -hex 32

APP_ENV=staging
NODE_ENV=production

JWT_SECRET=replace-with-openssl-rand-hex-32-staging-only
SITE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
VITE_APP_URL=http://localhost:8080
VITE_API_URL=/api

STAGING_FRONTEND_PORT=8080
STAGING_API_PORT=5001
STAGING_MONGO_PORT=27018
STAGING_REDIS_PORT=6380

MONGO_URI=mongodb://mongodb:27017/edurozgaar
REDIS_URL=redis://redis:6379
REQUIRE_REDIS=1

LOG_LEVEL=info
# SENTRY_DSN=

# Durable media: use local volume in compose, or switch to s3/supabase for staging parity with prod
MEDIA_STORAGE_PROVIDER=local
# MEDIA_STORAGE_PROVIDER=s3
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_CDN_URL=https://cdn.staging.example.com
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
# SUPABASE_CDN_URL=

# SMTP (validate before Beta)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=EduRozgaar Staging <noreply@staging.example.com>

# Stripe — optional on staging
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

WORKER_POLL_INTERVAL_MS=15000
CMS_SEED_ON_START=0

# --- Feature flag matrix (Beta-safe) ---
TALENT_PROFILE_ENABLED=1
TALENT_PROFILE_DUAL_WRITE=0
TALENT_PROFILE_READ_CANONICAL=0
VITE_TALENT_PROFILE_ENABLED=1
OPPORTUNITY_APPLICATION_ENABLED=1
VITE_OPPORTUNITY_APPLICATION_ENABLED=1
APPLICATION_DUAL_WRITE=0
APPLICATION_READ_CANONICAL=0
TIMELINE_ENABLED=1
VITE_TIMELINE_ENABLED=1
DOCUMENTS_PLATFORM_ENABLED=1
VITE_DOCUMENTS_PLATFORM_ENABLED=1
CAREER_DASHBOARD_ENABLED=1
VITE_CAREER_DASHBOARD_ENABLED=1
CAREER_DASHBOARD_V2_ENABLED=1
VITE_CAREER_DASHBOARD_V2_ENABLED=1
DASHBOARD_PERSONALIZATION_ENABLED=0
VITE_DASHBOARD_PERSONALIZATION_ENABLED=0
SCORING_ENABLED=1
VITE_SCORING_ENABLED=1
ASSESSMENTS_ENABLED=1
VITE_ASSESSMENTS_ENABLED=1
ASSESSMENT_RESULTS_ENABLED=1
VERIFIED_CREDENTIALS_ENABLED=1
EMPLOYER_INTELLIGENCE_ENABLED=1
VITE_EMPLOYER_INTELLIGENCE_ENABLED=1
CAREER_MIGRATION_JOBS_ENABLED=0
DOCUMENTS_MIGRATION_ENABLED=0

# Paid AI: leave unset / do not add OPENAI_API_KEY / ANTHROPIC_API_KEY
# Monthly AI cost target: ≈ $0
