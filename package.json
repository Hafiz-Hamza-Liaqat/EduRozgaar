{
  "name": "strideto-e-portal",
  "version": "1.0.0",
  "description": "Strideto – Pakistan Job & Education E-Portal",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix client",
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "dev:all": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "dev-all": "npm run dev:all",
    "build": "npm run build --prefix client",
    "build:seo": "npm run build --prefix client && node scripts/prerender-seo.mjs",
    "start:server": "npm run start --prefix server",
    "seed": "npm run seed --prefix server",
    "verify:registry": "node scripts/verify-page-registry.mjs",
    "verify:blocks": "node scripts/verify-block-registry.mjs",
    "verify:page-builder-draft": "node scripts/verify-page-builder-draft-isolation.mjs",
    "verify:page-builder-dnd": "node scripts/verify-page-builder-dnd.mjs",
    "verify:block-templates": "node scripts/verify-block-templates.mjs",
    "verify:page-builder-history": "node scripts/verify-page-builder-history.mjs",
    "verify:page-builder-layout": "node scripts/verify-page-builder-layout.mjs",
    "verify:page-builder-production": "node scripts/verify-page-builder-production.mjs",
    "verify:media-library": "node scripts/verify-media-library.mjs",
    "verify:forms": "node scripts/verify-forms.mjs",
    "verify:dynamic-blocks": "node scripts/verify-dynamic-blocks.mjs",
    "verify:search": "node scripts/verify-search.mjs",
    "verify:analytics": "node scripts/verify-analytics.mjs",
    "verify:workflow": "node scripts/verify-workflow.mjs",
    "verify:platform-audit": "node scripts/verify-platform-audit.mjs",
    "verify:integration": "node scripts/verify-integration.mjs",
    "verify:localization": "node scripts/verify-localization.mjs",
    "verify:talent-profile": "node scripts/verify-talent-profile.mjs",
    "verify:career-domain": "node scripts/verify-career-domain.mjs",
    "verify:profile-adoption": "node scripts/verify-profile-adoption.mjs",
    "verify:opportunity-application": "node scripts/verify-opportunity-application.mjs",
    "verify:application-ui": "node scripts/verify-application-ui.mjs",
    "verify:application-tracker": "node scripts/verify-application-tracker.mjs",
    "verify:readiness": "node scripts/verify-readiness.mjs",
    "verify:assessments": "node scripts/verify-assessments.mjs",
    "verify:employer-intelligence": "node scripts/verify-employer-intelligence.mjs",
    "verify:career-launch-readiness": "node scripts/verify-career-launch-readiness.mjs",
    "verify:l2-6-5": "node scripts/verify-l2-6-5-beta.mjs",
    "verify:l2-8": "node scripts/verify-l2-8.mjs",
    "verify:timeline": "node scripts/verify-timeline.mjs",
    "verify:documents": "node scripts/verify-documents.mjs",
    "verify:career-dashboard": "node scripts/verify-career-dashboard.mjs",
    "verify:career-dashboard-v2": "node scripts/verify-career-dashboard-v2.mjs",
    "verify:migration": "node scripts/verify-migration.mjs",
    "verify:career-platform": "node scripts/verify-career-platform.mjs",
    "verify:production": "node scripts/verify-production.mjs",
    "verify:deployment": "node scripts/verify-deployment.mjs",
    "verify:staging": "node scripts/verify-staging.mjs",
    "staging:smoke": "node scripts/smoke-test.mjs",
    "verify:redis": "node scripts/verify-redis.mjs",
    "verify:queues": "node scripts/verify-queues.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "verify:monitoring": "node scripts/verify-monitoring.mjs",
    "verify:backups": "node scripts/verify-backups.mjs",
    "verify:performance": "node scripts/verify-performance.mjs",
    "load-test": "node scripts/load-test.mjs",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "verify:placements": "node scripts/verify-placement-coverage.mjs",
    "verify:ad-tracking": "node scripts/verify-ad-tracking.mjs",
    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "format": "prettier --write \"client/src/**/*.{js,jsx,ts,tsx,json,css,md}\" \"server/src/**/*.{js,ts,json,md}\""
  },
  "keywords": ["education", "jobs", "pakistan", "scholarships", "admissions"],
  "author": "Syed Daniyal Abbas",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.2.5"
  }
}
